}
.btn-submit.data-v-c53677aa { width: 100%; height: 88rpx; background: #000; color: #fff; border-radius: 44rpx; font-size: 30rpx; font-weight: 600; border: none; margin-top: 20rpx;
}
.btn-submit.data-v-c53677aa::after { border: none;
}
