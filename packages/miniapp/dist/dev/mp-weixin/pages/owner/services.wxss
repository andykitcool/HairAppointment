
.container.data-v-c53677aa { min-height: 100vh; background: var(--color-bg, #F5F5F5); padding: 30rpx; padding-bottom: 60rpx;
}
.header-row.data-v-c53677aa { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30rpx;
}
.page-title.data-v-c53677aa { font-size: 34rpx; font-weight: 700; color: #1A1A1A;
}
.btn-add.data-v-c53677aa { font-size: 26rpx; background: #000; color: #fff; padding: 12rpx 28rpx; border-radius: 32rpx; border: none;
}
.btn-add.data-v-c53677aa::after { border: none;
}
.loading-state.data-v-c53677aa, .empty-state.data-v-c53677aa { text-align: center; padding: 80rpx 0;
}
.loading-text.data-v-c53677aa, .empty-text.data-v-c53677aa { font-size: 28rpx; color: #999;
}
.service-list.data-v-c53677aa { display: flex; flex-direction: column; gap: 16rpx;
}
.service-card.data-v-c53677aa { background: #fff; border-radius: 16rpx; padding: 24rpx;
}
.card-main.data-v-c53677aa { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx;
}
.card-left.data-v-c53677aa { flex: 1; min-width: 0;
}
.service-name.data-v-c53677aa { font-size: 30rpx; font-weight: 600; color: #1A1A1A; display: block; margin-bottom: 6rpx;
}
.service-meta.data-v-c53677aa { font-size: 26rpx; color: #999;
}
.category-tag.data-v-c53677aa { font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 8rpx; flex-shrink: 0;
}
.category-tag.cut.data-v-c53677aa { background: #F5F5F5; color: #333;
}
.category-tag.perm.data-v-c53677aa { background: #FFF5E6; color: #FF9500;
}
.category-tag.dye.data-v-c53677aa { background: #E6F0FF; color: #1677FF;
}
.category-tag.care.data-v-c53677aa { background: #E6F9EE; color: #07C160;
}
.card-actions.data-v-c53677aa { display: flex; gap: 12rpx;
}
.btn-sm.data-v-c53677aa { font-size: 24rpx; padding: 10rpx 24rpx; border-radius: 8rpx; line-height: 1.2; border: none;
}
.btn-sm.data-v-c53677aa::after { border: none;
}
.btn-outline.data-v-c53677aa { background: none; color: #1A1A1A; border: 1rpx solid #E0E0E0;
}
.btn-red.data-v-c53677aa { background: none; color: #FA5151; border: 1rpx solid #FA5151;
}

/* 弹窗 */
.modal-mask.data-v-c53677aa { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 999; display: flex; align-items: flex-end;
}
.modal-box.data-v-c53677aa { width: 100%; background: #fff; border-radius: 24rpx 24rpx 0 0; padding: 40rpx 30rpx 60rpx; max-height: 80vh; overflow-y: auto;
}
.modal-title.data-v-c53677aa { font-size: 32rpx; font-weight: 700; color: #1A1A1A; display: block; margin-bottom: 30rpx;
}
.form-group.data-v-c53677aa { margin-bottom: 24rpx;
}
.form-row.data-v-c53677aa { display: flex; gap: 20rpx;
}
.half.data-v-c53677aa { flex: 1;
}
.form-label.data-v-c53677aa { font-size: 26rpx; color: #666; display: block; margin-bottom: 10rpx;
}
.form-input.data-v-c53677aa { width: 100%; height: 80rpx; background: #F5F5F5; border-radius: 12rpx; padding: 0 20rpx; font-size: 28rpx;
}
.form-textarea.data-v-c53677aa { width: 100%; height: 160rpx; background: #F5F5F5; border-radius: 12rpx; padding: 20rpx; font-size: 28rpx;
}
.category-picker.data-v-c53677aa { display: flex; gap: 16rpx; flex-wrap: wrap;
}
.cat-item.data-v-c53677aa { padding: 12rpx 28rpx; border-radius: 24rpx; background: #F5F5F5;
}
.cat-item.active.data-v-c53677aa { background: #000;
}
.cat-text.data-v-c53677aa { font-size: 26rpx; color: #666;
}
