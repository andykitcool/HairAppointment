}
.bottom-bar.data-v-dc52cf30 { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 20rpx 30rpx; padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}
.total-row.data-v-dc52cf30 { display: flex; justify-content: flex-end; align-items: baseline; margin-bottom: 16rpx;
