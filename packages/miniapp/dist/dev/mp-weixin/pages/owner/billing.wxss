}
.item-price.data-v-dc52cf30 { flex: 1.2;
}
.item-qty.data-v-dc52cf30 { flex: 0.8;
}
.item-del.data-v-dc52cf30 { font-size: 36rpx; color: #FA5151; padding: 0 8rpx;
}
.pay-grid.data-v-dc52cf30 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12rpx;
}
.pay-item.data-v-dc52cf30 { padding: 16rpx; border-radius: 10rpx; text-align: center; border: 2rpx solid #E0E0E0;
