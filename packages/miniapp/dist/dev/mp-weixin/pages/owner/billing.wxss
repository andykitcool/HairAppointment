.item-row.data-v-dc52cf30 { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx;
}
.item-input.data-v-dc52cf30 { height: 68rpx; background: #F5F5F5; border-radius: 10rpx; padding: 0 14rpx; font-size: 26rpx;
}
