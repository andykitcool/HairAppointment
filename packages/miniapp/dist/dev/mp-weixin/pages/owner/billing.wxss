
.container.data-v-dc52cf30 { min-height: 100vh; background: var(--color-bg, #F5F5F5); padding: 30rpx; padding-bottom: 200rpx;
}
.page-title.data-v-dc52cf30 { font-size: 34rpx; font-weight: 700; color: #1A1A1A; display: block; margin-bottom: 30rpx;
}
.section.data-v-dc52cf30 { margin-bottom: 30rpx; background: #fff; border-radius: 16rpx; padding: 24rpx;
}
.section-header.data-v-dc52cf30 { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx;
}
.section-label.data-v-dc52cf30 { font-size: 28rpx; font-weight: 600; color: #1A1A1A; display: block; margin-bottom: 16rpx;
}
.section-header .section-label.data-v-dc52cf30 { margin-bottom: 0;
}
.link-text.data-v-dc52cf30 { font-size: 26rpx; color: #000; font-weight: 500;
}
.picker-btn.data-v-dc52cf30 { background: #F5F5F5; padding: 16rpx 20rpx; border-radius: 12rpx; font-size: 28rpx; color: #1A1A1A;
}
.form-group.data-v-dc52cf30 { margin-bottom: 16rpx;
}
.form-label.data-v-dc52cf30 { font-size: 24rpx; color: #666; display: block; margin-bottom: 8rpx;
}
.form-input.data-v-dc52cf30 { width: 100%; height: 76rpx; background: #F5F5F5; border-radius: 12rpx; padding: 0 20rpx; font-size: 28rpx;
}
.form-textarea.data-v-dc52cf30 { width: 100%; height: 120rpx; background: #F5F5F5; border-radius: 12rpx; padding: 20rpx; font-size: 28rpx;
}
.apt-list-mini.data-v-dc52cf30 { max-height: 200rpx; overflow-y: auto;
}
.apt-chip.data-v-dc52cf30 { padding: 14rpx 16rpx; border-radius: 8rpx; margin-bottom: 8rpx; border: 2rpx solid transparent;
