# 镜像仓库前缀，例如 registry.cn-hangzhou.aliyuncs.com/your-namespace/hairappointment
IMAGE_PREFIX=registry.example.com/your-namespace/hairappointment

# 本次部署使用的镜像版本，例如 2026.04.10-1 或 git commit sha
IMAGE_TAG=latest

# 可选：如果 Mongo / Redis 也使用私有镜像，可在这里覆盖
MONGO_IMAGE=mongo:7
REDIS_IMAGE=redis:7-alpine

# API 运行参数
MONGODB_URI=mongodb://mongo:27017/hair_appointment
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
JWT_SECRET=replace_with_a_strong_random_secret
CORS_ALLOWED_ORIGINS=https://admin.example.com
PORT=3000

# 微信小程序配置
WX_APPID=your_wechat_appid
WX_APPSECRET=your_wechat_appsecret