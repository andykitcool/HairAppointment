{
  "name": "hair-appointment",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.5",
  "description": "美发预约记账系统 - Monorepo",
  "scripts": {
    "dev:server": "pnpm --filter @hair/server dev",
    "dev:miniapp": "pnpm --filter @hair/miniapp dev:mp-weixin",
    "dev:admin": "pnpm --filter @hair/admin dev",
    "build:server": "pnpm --filter @hair/server build",
    "build:miniapp": "pnpm --filter @hair/miniapp build:mp-weixin",
    "build:admin": "pnpm --filter @hair/admin build",
    "build:shared": "pnpm --filter @hair/shared build",
    "lint": "eslint packages/*/src --ext .ts,.vue",
    "clean": "rimraf packages/*/dist"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@koa/cors": "^5.0.0",
    "@koa/router": "^15.4.0",
    "@noble/hashes": "^2.0.1",
    "@paralleldrive/cuid2": "^3.3.0",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "koa": "^3.2.0",
    "koa-body": "^7.0.1",
    "koa-router": "^14.0.0",
    "mongoose": "^9.4.1",
    "node-cron": "^4.2.1"
  }
}
